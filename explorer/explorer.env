# ============================================================
#  bch-rpc-explorer – Konfiguration
#  Alle Werte können auch als Umgebungsvariablen gesetzt werden.
#  Docs: https://github.com/tajorey/bch-rpc-explorer#configuration
# ============================================================

# --- BCHN RPC-Verbindung ---
# Feste IP des bchn-Containers im Docker-Netzwerk
BTCEXP_BITCOIND_HOST=172.28.0.10
BTCEXP_BITCOIND_PORT=8332
BTCEXP_BITCOIND_USER=bchuser
BTCEXP_BITCOIND_PASS=AENDERN_SICHERES_PASSWORT_HIER

# --- Explorer-Einstellungen ---
# Port des Web-Interfaces
BTCEXP_PORT=3002

# Anzahl gleichzeitiger RPC-Verbindungen zum Node
# Nicht zu hoch setzen – der Node limitiert RPC-Threads
BTCEXP_RPC_CONCURRENCY=5

# Lokaler Cache für RPC-Antworten (Sekunden)
# Reduziert Last auf dem Node erheblich
BTCEXP_SLOW_DEVICE_MODE=false
BTCEXP_NO_INMEMORY_RPC_CACHE=false

# --- Coin konfigurieren ---
BTCEXP_COIN=BCH

# --- Sicherheit ---
# Passwortschutz für das Web-Interface (leer = kein Schutz)
# Empfehlung: setzen, wenn der Port nach außen erreichbar ist
BTCEXP_BASIC_AUTH_PASSWORD=

# --- Privatsphäre ---
# Externe Preis-APIs deaktivieren (kein Internetzugriff nötig)
BTCEXP_NO_RATES=true

# --- Netzwerk-Timeout ---
BTCEXP_BITCOIND_RPC_TIMEOUT=10000
